{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-remote:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git rev-parse:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(go:*)",
      "Bash(buf:*)",
      "Bash(make:*)",
      "Bash(npm ci:*)",
      "Bash(npm i @x-asia/farm-api-typescript-openapi*)",
      "Bash(npm install @x-asia/farm-api-typescript-openapi*)",
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(basename:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(open:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      "Bash(seq:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(chmod:*)",
      "Bash(dd:*)",
      "Bash(fdisk:*)",
      "Bash(mkfs:*)",
      "Bash(rm -f:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(nc:*)",
      "Bash(wget:*)",
      "Bash(npm publish:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(psql:*)",
      "Edit(.env)",
      "Edit(/etc/**)",
      "Edit(/usr/**)",
      "Edit(/var/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*token*)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(~/.ssh/**)",
      "mcp__supabase__execute_sql"
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "enableallprojectmcpservers": true,
  "enabledmcpjsonservers": [
    "notion",
    "figma-remote-mcp"
  ],
  "defaultMode": "default"
}
